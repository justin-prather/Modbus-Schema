{
  "name": "modbus-schema",
  "version": "0.1.0",
  "description": "Device-agnostic Effect Schema generators for Modbus register values, with both Effect-native and synchronous APIs.",
  "type": "module",
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./package.json": "./package.json",
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "bun test src/",
    "test:coverage": "bun test --coverage src/",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf ./dist && bun build ./index.ts --outdir ./dist --target node --external effect && tsc --noEmit false --emitDeclarationOnly --outDir ./dist --rootDir . --project tsconfig.build.json"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.3",
    "@types/bun": "latest",
    "effect": "^3.21.4",
    "fallow": "^2.104.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "effect": "^3.21.4"
  },
  "license": "GPL-3.0"
}
